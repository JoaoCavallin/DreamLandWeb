@model IEnumerable<DreamLandWEB.Models.Produto>
@using DreamLandWEB.Helpers
@using DreamLandWEB.Enums

@{
    ViewData["Title"] = "DreamLand";
}

<div class="text-center mb-4">
    <h1>DreamLand</h1>
    <p class="text-muted">Roupas e itens infantis com carinho, prontos para uma nova história</p>
</div>

<form method="get" class="d-flex justify-content-center mb-4">
    <select name="categoria" class="form-select w-auto" onchange="this.form.submit()"
            asp-items="Html.GetEnumSelectList<CategoriaProduto>()">
        <option value="">Todas as categorias</option>
    </select>
</form>

@if (!Model.Any())
{
    <p class="text-center text-muted">Nenhum produto disponível no momento.</p>
}

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var produto in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                {
                    <img src="@produto.ImagemUrl" class="card-img-top" alt="@produto.Nome" style="height:200px; object-fit:cover;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                        <span class="text-muted">Sem imagem</span>
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@produto.Nome</h5>
                    <p class="card-text text-muted mb-1">
                        @produto.Categoria.GetDisplayName() &middot; Tam. @produto.Tamanho
                    </p>
                    <p class="card-text mb-1">
                        <span class="badge bg-secondary">@produto.Condicao.GetDisplayName()</span>
                    </p>
                    <p class="card-text fw-bold fs-5 mt-auto">R$ @produto.Preco.ToString("F2")</p>
                    <a asp-controller="Produtos" asp-action="Details" asp-route-id="@produto.Id" class="btn btn-outline-primary mt-2">Ver Detalhes</a>
                </div>
            </div>
        </div>
    }
</div>